# AI API Configuration
# Required: OpenAI-compatible API key (also accepts AI_API_KEY)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom API endpoint for OpenAI-compatible providers (e.g. Dashscope, Azure)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use for AI analysis
# Default: gpt-4o-mini
AI_MODEL=gpt-4o-mini
